# -------------------------------------------------------------------
# USB-DnD-LLM local/runtime files
# These files are downloaded/generated on the USB/SSD and should not be repo code
# -------------------------------------------------------------------

# Heavy AI models / Ollama / llama.cpp runtime data
Shared/models/*
!Shared/models/.gitkeep

Shared/.ollama-runtime/
Shared/ollama/
Shared/ollama_data/
Shared/installed-models.txt
Shared/Modelfile*
Shared/**/*.gguf
Shared/**/*.bin
Shared/**/*.safetensors

# Downloaded engines, binaries, runtimes
Shared/bin/*
!Shared/bin/.gitkeep

Shared/vendor/
Shared/python/
Shared/node_modules/
Shared/*.zip
Shared/*.tar
Shared/*.tar.gz
Shared/*.tgz
Shared/*.7z

# Generic chat history, local settings, logs
Shared/chat_data/*
!Shared/chat_data/.gitkeep

Shared/logs/*
!Shared/logs/.gitkeep

Shared/**/*.log
Shared/**/*_history.json
Shared/**/settings.json

